{
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "manifest.json", "use": "@vercel/static" },
    { "src": "sw.js", "use": "@vercel/static" },
    { "src": "css/**", "use": "@vercel/static" },
    { "src": "js/**", "use": "@vercel/static" },
    { "src": "images/**", "use": "@vercel/static" },
    { "src": "downloads/**", "use": "@vercel/static" },
    { "src": "server.cjs", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/admin", "dest": "/index.html" },
    { "src": "/admin.html", "dest": "/index.html" },
    { "src": "/login", "dest": "/login.html" },
    { "src": "/downloads/(.*)", "dest": "server.cjs" },
    { "src": "/api/(.*)", "dest": "server.cjs" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}

